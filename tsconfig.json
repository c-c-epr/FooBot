{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "WebWorker"],

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,

    "types": ["@cloudflare/workers-types"],

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
